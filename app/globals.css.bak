/* 1. ตั้งค่าพื้นฐาน (Reset & Fonts) */
:root {
  --primary-blue: #003366;    /* สีน้ำเงินเข้ม ดูน่าเชื่อถือ */
  --secondary-blue: #0056b3;  /* สีน้ำเงินสว่าง สำหรับปุ่ม */
  --accent-gold: #d4af37;     /* สีทอง สำหรับเน้นราคาหรือจุดสำคัญ */
  --text-dark: #2d3436;       /* สีตัวอักษรหลัก */
  --text-light: #636e72;      /* สีตัวอักษรรอง */
  --bg-white: #ffffff;
  --bg-light: #f8f9fa;
}

* {
  box-sizing: border-box;
  padding: 0;
  margin: 0;
}

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  color: var(--text-dark);
  background-color: var(--bg-white);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* 2. จัดการ Typography (SEO Tip: หัวข้อต้องชัดเจน) */
h1, h2, h3 {
  color: var(--primary-blue);
  font-weight: 800;
  line-height: 1.2;
}

h1 { font-size: 2.8rem; margin-bottom: 1.5rem; }
h2 { font-size: 2rem; margin-bottom: 1.2rem; }
h3 { font-size: 1.5rem; margin-bottom: 1rem; }

p {
  margin-bottom: 1rem;
  font-size: 1.1rem;
  color: var(--text-light);
}

/* 3. Layout Helper */
.container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 20px;
}

/* 4. ปรับแต่งปุ่ม (Call to Action) */
button {
  background-color: var(--secondary-blue);
  color: white;
  padding: 15px 35px;
  border: none;
  border-radius: 50px;
  font-size: 1.1rem;
  font-weight: bold;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 4px 15px rgba(0, 86, 179, 0.3);
}

button:hover {
  background-color: var(--primary-blue);
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(0, 51, 102, 0.4);
}

/* 5. ตกแต่งกล่องบริการ (Service Cards) */
.service-card {
  transition: transform 0.3s ease;
  border: 1px solid rgba(0,0,0,0.05);
}

.service-card:hover {
  transform: translateY(-5px);
}

/* 6. ส่วนเน้นราคา (Pricing Highlight) */
.price-tag {
  color: var(--primary-blue) !important;
  background: linear-gradient(120deg, #fff9c4 0%, #fff9c4 100%);
  display: inline-block;
  padding: 2px 10px;
  border-radius: 4px;
}

/* 7. Responsive (สำหรับมือถือ) */
@media (max-width: 768px) {
  h1 { font-size: 2.2rem; }
  h2 { font-size: 1.7rem; }
  section { padding: 40px 10px !important; }
}