import { getAllPosts } from '../lib/posts';

export default async function sitemap() {
  // 1. กำหนดชื่อโดเมนหลักของคุณ (อย่าลืมเปลี่ยนเป็นโดเมนจริงเมื่อออนไลน์)
  const baseUrl = "https://www.yourdomain.com";

  // 2. ดึงข้อมูลบทความทั้งหมดจากไฟล์ Markdown ผ่านฟังก์ชันใน lib/posts.js
  // ฟังก์ชันนี้จะส่งกลับมาเป็น Array ของวัตถุที่มี { slug, date, ... }
  const posts = getAllPosts();

  // 3. แปลงข้อมูลบทความเป็นรูปแบบ URL สำหรับ Sitemap
  const blogUrls = posts.map((post) => ({
    url: `${baseUrl}/blog/${post.slug}`,
    // หากใน Markdown มีฟิลด์ date ให้ใช้ค่านั้น ถ้าไม่มีให้ใช้เครื่องปัจจุบัน
    lastModified: post.date ? new Date(post.date) : new Date(),
    changeFrequency: 'weekly',
    priority: 0.7, // ให้ความสำคัญรองลงมาจากหน้าหลัก
  }));

  // 4. กำหนดหน้าหลักที่คงที่ (Static Pages)
  const staticUrls = [
    {
      url: baseUrl,
      lastModified: new Date(),
      changeFrequency: 'monthly',
      priority: 1.0, // หน้าแรกสำคัญที่สุด
    },
    {
      url: `${baseUrl}/blog`,
      lastModified: new Date(),
      changeFrequency: 'daily', // หน้าสารบัญบทความควรให้ Bot มาเช็คบ่อยๆ
      priority: 0.9,
    },
  ];

  // 5. รวม URL ทั้งหมดและส่งกลับไปให้ Next.js สร้างไฟล์ XML
  return [...staticUrls, ...blogUrls];
}